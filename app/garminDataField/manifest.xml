        name="@Strings.AppName"
        entry="FtmsDataFieldApp"
        launcherIcon="@Drawables.LauncherIcon"
        minApiLevel="5.0.0"
        version="1.0.0">

        <iq:products>
            <!-- New/current Forerunner line. Build target: fr970 for Forerunner 970. -->
            <iq:product id="fr970"/>
            <iq:product id="fr57047mm"/>
            <iq:product id="fr57042mm"/>
            <iq:product id="fr170"/>
            <iq:product id="fr170m"/>
            <iq:product id="fr70"/>

            <!-- Useful older test targets. Remove if you want the first release to be FR970-only. -->
            <iq:product id="fr965"/>
            <iq:product id="fr955"/>
